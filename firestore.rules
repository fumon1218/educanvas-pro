rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: boards
    // Document ID: {boardId}
    // Fields:
    //   - name: string (required, max 100 chars)
    //   - ownerId: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (required)
    //
    // Collection: boards/{boardId}/scenes
    // Document ID: {sceneId}
    // Fields:
    //   - name: string (required, max 100 chars)
    //   - data: string (required, max 900000 chars)
    //   - order: number (required)
    //   - updatedAt: timestamp (required)
    //   - updatedBy: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }
    
    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidBoard(data) {
      return hasOnlyAllowedFields(['name', 'ownerId', 'createdAt', 'updatedAt']) &&
             isValidString('name', 1, 100) &&
             data.ownerId is string &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }
    
    function isValidScene(data) {
      return hasOnlyAllowedFields(['name', 'data', 'order', 'updatedAt', 'updatedBy']) &&
             isValidString('name', 1, 100) &&
             isValidString('data', 0, 900000) && // Max ~900KB for Firestore limits
             data.order is number &&
             data.updatedAt is timestamp &&
             data.updatedBy is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /boards/{boardId} {
      // Anyone authenticated can read boards (for collaboration via link)
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
                       isValidBoard(request.resource.data) &&
                       request.resource.data.ownerId == request.auth.uid;
                       
      allow update: if isAuthenticated() && 
                       isValidBoard(request.resource.data) &&
                       resource.data.ownerId == request.resource.data.ownerId && // ownerId is immutable
                       resource.data.createdAt == request.resource.data.createdAt; // createdAt is immutable
                       
      allow delete: if isOwner(resource.data.ownerId);
      
      match /scenes/{sceneId} {
        // Anyone authenticated can read scenes of a board
        allow read: if isAuthenticated();
        
        // Anyone authenticated can create/update scenes (collaborative)
        allow create: if isAuthenticated() && 
                         isValidScene(request.resource.data) &&
                         request.resource.data.updatedBy == request.auth.uid;
                         
        allow update: if isAuthenticated() && 
                         isValidScene(request.resource.data) &&
                         request.resource.data.updatedBy == request.auth.uid;
                         
        allow delete: if isAuthenticated(); // Or restrict to board owner if needed
      }
    }
  }
}
